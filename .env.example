# Token de acesso da Meta (Sistema User do BM, nunca expira)
# Gerado em: BM → Usuários do sistema → Admin → Gerar token → expiração: nunca
# Permissões necessárias: ads_management, ads_read
META_ACCESS_TOKEN=

# Versão da Graph API
META_API_VERSION=v24.0

# Secret para validar requisições recebidas do Kommo/Evolution/Z-API
# Qualquer string aleatória segura (ex: openssl rand -hex 32)
WEBHOOK_SECRET=

# (Opcional) Código de teste do Meta Events Manager para validar sem contar como evento real
# Encontra em: Events Manager → Pixel de Mensagens → Test Events → código TEST_xxxxx
# Deixar vazio em produção
META_TEST_EVENT_CODE=
